# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit secrets.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase Edge Function secrets. Set these with:
# npx supabase secrets set --project-ref YOUR_PROJECT_REF NAME=value
# Required for structuring OCR text with Zhipu AI GLM-4-Flash.
AI_PROVIDER=zhipu
ZHIPU_API_KEY=xxxxxxxxxxxxxxxx
ZHIPU_TEXT_MODEL=glm-4-flash-250414

# Optional fallback if AI_PROVIDER=dashscope.
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx
DASHSCOPE_TEXT_MODEL=qwen-plus
# Cloud OCR fallback is disabled unless this is explicitly true.
ENABLE_CLOUD_OCR_FALLBACK=false
# Required only when cloud OCR fallback is explicitly enabled.
ALIYUN_OCR_ENDPOINT=https://your-ocr-endpoint.example.com
ALIYUN_OCR_APPCODE=xxxxxxxx
# Or use ALIYUN_OCR_API_KEY instead of ALIYUN_OCR_APPCODE if your endpoint expects Bearer auth.
ALIYUN_OCR_API_KEY=xxxxxxxx
